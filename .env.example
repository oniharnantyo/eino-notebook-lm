# Eino Notebook Environment Configuration
# Copy this file to .env and update with your values

# Server Configuration
SERVER_HOST=localhost
SERVER_PORT=8080
# Timeouts for HTTP server (increase for large file uploads/processing)
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s

# Logging (debug, info, warn, error)
LOG_LEVEL=info
# Log Format (json, text) - default: json
LOG_FORMAT=json

# PostgreSQL Database
DATABASE_DRIVER=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=eino_notebook

# Gemini
GEMINI_API_KEY=your_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Model Configuration (provider/model format)
# Supports: gemini/* or openai/*
CHAT_MODEL=gemini/gemini-2.0-flash-exp
EMBEDDING_MODEL=gemini/text-embedding-004
EMBEDDING_DIMENSION=768

# OpenAI (optional - only needed when using openai/* models)
#OPENAI_API_KEY=your_openai_api_key_here
#OPENAI_BASE_URL=http://192.168.100.10:8034/v1

# Kreuzberg Document Parser
KREUZBERG_SERVICE_URL=http://localhost:8000
KREUZBERG_OUTPUT_FORMAT=markdown
KREUZBERG_TIMEOUT=30s
# Optional: Return each page as a separate document
# KREUZBERG_TO_PAGES=false

# Optional: Quality Processing
# KREUZBERG_ENABLE_QUALITY_PROCESSING=true
# KREUZBERG_FORCE_OCR=true
# KREUZBERG_RESULT_FORMAT=element_based
# KREUZBERG_INCLUDE_DOCUMENT_STRUCTURE=true

# Optional: OCR Configuration for scanned documents
# KREUZBERG_OCR_BACKEND=paddleocr
# KREUZBERG_OCR_LANGUAGE=eng
# KREUZBERG_OCR_MODEL=
# KREUZBERG_OCR_PADDLE_MODEL_TIER=mobile
# KREUZBERG_OCR_PADDLE_PADDING=10

# Optional: Table Extraction
# KREUZBERG_TABLE_EXTRACTION_MODE=

# Optional: PDF Options
# KREUZBERG_PDF_OPTIONS_EXTRACT_IMAGES=false
# KREUZBERG_PDF_OPTIONS_EXTRACT_METADATA=true
# KREUZBERG_PDF_OPTIONS_HIERARCHY_ENABLED=false
# KREUZBERG_PDF_OPTIONS_HIERARCHY_K_CLUSTERS=6
# KREUZBERG_PDF_OPTIONS_HIERARCHY_INCLUDE_BBOX=false
# KREUZBERG_PDF_OPTIONS_HIERARCHY_OCR_COVERAGE_THRESHOLD=0.5

# Optional: Images Options
# KREUZBERG_IMAGES_EXTRACT_IMAGES=false
# KREUZBERG_IMAGES_INJECT_PLACEHOLDERS=true

# Optional: Pages Options
# KREUZBERG_PAGES_EXTRACT_PAGES=true
# KREUZBERG_PAGES_INSERT_PAGE_MARKERS=true
# KREUZBERG_PAGES_MARKER_FORMAT="\n\n\n\n"

# Optional: Layout Options
# KREUZBERG_LAYOUT_PRESET=accurate
# KREUZBERG_LAYOUT_APPLY_HEURISTICS=true

# Document Transformer
TRANSFORMER_TYPE=recursive
TRANSFORMER_CHUNK_SIZE=4000
TRANSFORMER_OVERLAP_SIZE=800
# Options:
# - TRANSFORMER_TYPE: recursive (overlap chunking) or markdown (header-based splitting)
# - TRANSFORMER_CHUNK_SIZE: Maximum characters per chunk (default: 4000)
# - TRANSFORMER_OVERLAP_SIZE: Overlap characters between chunks (default: 800, must be less than CHUNK_SIZE)

# Langfuse Observability
LANGFUSE_ENABLED=false
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxx
LANGFUSE_SAMPLE_RATE=1.0
LANGFUSE_RELEASE=v1.0.0
